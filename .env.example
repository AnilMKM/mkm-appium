# ─── Local Appium (default) ───────────────────────────────────────────────────
# Override which simulator/emulator to target
# PLATFORM=ios                       # ios | android
# BUNDLE_ID=com.mkm.ecommerce.dev
# IOS_DEVICE=iPhone 17 Pro
# IOS_VERSION=26.3
# ANDROID_DEVICE=emulator-5554

# ─── BrowserStack App Automate ────────────────────────────────────────────────
# Set these to switch from local Appium to BrowserStack (both are required)
# BROWSERSTACK_USERNAME=your_username
# BROWSERSTACK_ACCESS_KEY=your_access_key

# App to test — upload first, then paste the returned bs://... URL here
# BS_APP_ID=bs://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Device/OS to run on (optional — defaults shown)
# BS_IOS_DEVICE=iPhone 14
# BS_IOS_VERSION=16
# BS_ANDROID_DEVICE=Samsung Galaxy S23
# BS_ANDROID_VERSION=13.0

# Session metadata shown in the BrowserStack dashboard (optional)
# BS_PROJECT=MKM App
# BS_BUILD=Local Build
# BS_SESSION=E2E Tests

# Set to true to capture full Appium logs in the BrowserStack dashboard
# BS_APPIUM_LOGS=false
